          "evidence_type": { "type": "keyword" },
          "title": {
            "type": "text",
            "analyzer": "metis_content_analyzer",
            "fields": {
              "keyword": { "type": "keyword" }
            }
          },
          "description": {
            "type": "text",
            "analyzer": "metis_content_analyzer"
          },
          "content_text": {
            "type": "text",
            "analyzer": "metis_content_analyzer"
          },
          "content_url": { "type": "keyword" },
          "tags": { "type": "keyword" },
          "metadata": { "type": "object" },
          "captured_at": { "type": "date" },
          "created_at": { "type": "date" },
          "reliability_score": { "type": "float" }
        }
      }
    },
