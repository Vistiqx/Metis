# Metis Platform Environment Configuration
# Copy this file to .env and fill in your values
# NOTE: All ports have been updated to avoid common conflicts

# ============================================
# Port Configuration (Non-conflicting ports)
# ============================================
# Frontend: 3001 (was 5173)
# API: 8081 (was 8000)
# PostgreSQL: 5433 (was 5432)
# Redis: 6380 (was 6379)
# Neo4j HTTP: 7475 (was 7474)
# Neo4j Bolt: 7688 (was 7687)
# OpenSearch: 9201 (was 9200)
# MinIO API: 9002 (was 9000)
# MinIO Console: 9003 (was 9001)
# Prometheus: 9091 (was 9090)
# Grafana: 3002 (was 3000)

# ============================================
# Application Settings
# ============================================
APP_ENV=development
APP_NAME=Metis
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production

# ============================================
# Database Configuration
# ============================================
# PostgreSQL (Port 5433 to avoid conflict)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=metis
POSTGRES_USER=metis
POSTGRES_PASSWORD=metis_password_change_me

# PostGIS (same as PostgreSQL)
POSTGIS_HOST=localhost
POSTGIS_PORT=5433
POSTGIS_DB=metis_gis
POSTGIS_USER=metis
POSTGIS_PASSWORD=metis_password_change_me

# Neo4j (Ports 7475/7688 to avoid conflict)
NEO4J_HOST=localhost
NEO4J_PORT=7688
NEO4J_BOLT_PORT=7688
NEO4J_HTTP_PORT=7475
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password_change_me

# OpenSearch (Port 9201 to avoid conflict)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9201
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# Redis (Port 6380 to avoid conflict)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# Object Storage (S3-compatible)
# Ports 9002/9003 to avoid conflict
# ============================================
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=metis-evidence
S3_REGION=us-east-1
S3_USE_SSL=false

# ============================================
# API Keys & External Services
# ============================================
# Social Media / OSINT Sources
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Metis-OSINT/0.1.0

TELEGRAM_API_ID=
TELEGRAM_API_HASH=

YOUTUBE_API_KEY=

# News & RSS
NEWSAPI_KEY=

# AI / LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# Geocoding
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# ============================================
# Security & Authentication
# ============================================
JWT_SECRET_KEY=your-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (Updated ports)
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# ============================================
# Feature Flags
# ============================================
ENABLE_AI_ANALYST=true
ENABLE_VISUAL_INTELLIGENCE=false
ENABLE_THREAT_MODELING=true
ENABLE_AUTOMATED_REPORTING=false

# ============================================
# Monitoring & Logging (Updated ports)
# ============================================
LOG_LEVEL=INFO
SENTRY_DSN=
PROMETHEUS_PORT=9091
GRAFANA_PORT=3002

# ============================================
# Frontend Configuration (Updated ports)
# ============================================
VITE_API_BASE_URL=http://localhost:8081/api/v1
VITE_WS_URL=ws://localhost:8081/ws
